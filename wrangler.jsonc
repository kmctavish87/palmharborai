{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "palmharborai",
  "compatibility_date": "2026-04-29",
  "main": "worker/index.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "TMS_DB",
      "database_name": "palmharborai-tms",
      "database_id": "7d154c0f-3e6d-46cc-baca-3dd75f727000"
    }
  ]
}
